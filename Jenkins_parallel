pipeline {
    agent any

    options {
        timestamps()
        skipDefaultCheckout(false)
        disableConcurrentBuilds()
    }

    environment {
        VENV_DIR       = "venv"
        OUTPUT_DIR     = "output"
        REQ_FILE       = "requirements.txt"
        TESTS_DIR      = "tests"
        ALLURE_RESULTS = "output/allure-results"
        ALLURE_REPORT  = "output/allure-report"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "==== Checking out source code from SCM ===="
                checkout scm
                sh 'pwd'
            }
        }

        stage('Validate Project Structure') {
            steps {
                echo "==== Validating project structure ===="
                sh '''
                    test -f requirements.txt || { echo "requirements.txt not found"; exit 1; }
                    test -d tests || { echo "tests directory not found"; exit 1; }
                    echo "Validation passed"
                '''
            }
        }

        stage('Setup Python Environment') {
            steps {
                echo "==== Setting up Python virtual environment ===="
                sh '''
                    if [ ! -d "$VENV_DIR" ]; then
                        python3 -m venv $VENV_DIR
                    fi

                    source $VENV_DIR/bin/activate

                    python -m pip install --upgrade pip
                '''
            }
        }

        stage('Install Dependencies') {
    steps {
        echo "==== Installing dependencies ===="
        sh '''
            set +e

            source $VENV_DIR/bin/activate

            pip install -r requirements.txt
            echo "pip exit code = $?"

            which python
            echo "which python exit code = $?"

            which robot
            echo "which robot exit code = $?"

            robot --version
            echo "robot exit code = $?"

            echo "Install stage completed"

            exit 0
        '''
    }
}

        stage('Execute Robot Tests') {
            steps {
                echo "==== Executing Robot Tests ===="
                sh '''
                    source $VENV_DIR/bin/activate

                    rm -rf $OUTPUT_DIR
                    mkdir -p $OUTPUT_DIR

                    pabot --processes 2 \
                        --outputdir $OUTPUT_DIR \
                        --listener allure_robotframework:$ALLURE_RESULTS \
                        $TESTS_DIR
                '''
            }
        }

        stage('Publish Reports') {
            steps {
                script {
                    if (fileExists("${env.OUTPUT_DIR}/output.xml")) {
                        step([
                            $class: 'RobotPublisher',
                            outputPath: "${env.OUTPUT_DIR}",
                            outputFileName: 'output.xml',
                            reportFileName: 'report.html',
                            logFileName: 'log.html'
                        ])
                    }
                }
            }
        }

        stage('Generate Allure Report') {
            steps {
                sh '''
                    if [ -d "$ALLURE_RESULTS" ]; then
                        if command -v allure >/dev/null 2>&1; then
                            allure generate "$ALLURE_RESULTS" \
                                -o "$ALLURE_REPORT" \
                                --clean || true
                        fi
                    fi
                '''
            }
        }

        stage('Generate Robot Metrics') {
            steps {
                sh '''
                    source $VENV_DIR/bin/activate

                    if [ -f "$OUTPUT_DIR/output.xml" ]; then
                        robotmetrics -I "$OUTPUT_DIR" || true
                    fi
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'output/**/*', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'output/**/*', allowEmptyArchive: true

            sh '''
                find . -type d -name "__pycache__" -exec rm -rf {} + || true
            '''
        }

        success {
            echo "Build SUCCESS"
        }

        unstable {
            echo "Build UNSTABLE"
        }

        failure {
            echo "Build FAILED"
        }
    }
}